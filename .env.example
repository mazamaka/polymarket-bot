# Polymarket Bot Configuration
# Copy this file to .env and fill in your values

# === API Keys ===
POLYGON_WALLET_PRIVATE_KEY=
POLYGON_WALLET_ADDRESS=
BOT_API_KEY=your-dashboard-api-key

# === Trading Mode ===
PAPER_TRADING=true
DEFAULT_TRADE_SIZE_USD=20.0

# === Proxy (if needed for geo-restricted regions) ===
CLOB_PROXY_URL=

# === News Intelligence Service (optional, for information arbitrage) ===
NEWS_SERVICE_URL=
SSE_ENABLED=true

# === Tavily Search (optional, for enriched market context) ===
TAVILY_API_KEY=

# === Risk Management ===
MAX_POSITION_PCT=0.05
MAX_TOTAL_EXPOSURE_PCT=0.60
MIN_EDGE_THRESHOLD=0.08
STOP_LOSS_PCT=0.40
TAKE_PROFIT_PCT=0.50

# === Weather Strategy ===
WEATHER_ENABLED=true
WEATHER_TRADE_SIZE_USD=3.0
WEATHER_MAX_POSITIONS=25
